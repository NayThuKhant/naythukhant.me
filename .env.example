# Nuxt Studio — Git repository (required for production publish)
STUDIO_REPO_OWNER=your-github-username
STUDIO_REPO_NAME=your-repo-name
STUDIO_REPO_BRANCH=main

# Nuxt Studio — GitHub OAuth (required for production auth)
STUDIO_GITHUB_CLIENT_ID=
STUDIO_GITHUB_CLIENT_SECRET=

# Vercel Analytics + Speed Insights (set to true only when you want those scripts injected)
VERCEL_ANALYTICS_SPEED_INSIGHTS_ENABLED=false

